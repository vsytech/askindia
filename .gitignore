# ─────────────────────────────────────────────────────────────────
#  AskIndia — .gitignore
# ─────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output (Vercel builds from source — never commit dist)
dist/
dist-ssr/
build/

# Environment secrets — NEVER commit real credentials
.env
.env.local
.env.*.local
# .env.example and .env.production (with placeholders) ARE committed

# Vite cache
.vite/
vite.config.ts.timestamp-*

# TypeScript incremental build cache
*.tsbuildinfo

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
