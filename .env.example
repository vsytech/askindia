# ─────────────────────────────────────────────────────────────────
#  AskIndia — India's Unified Marketplace
#  Environment Configuration  |  DO NOT COMMIT TO GIT
# ─────────────────────────────────────────────────────────────────
#  All browser-facing vars MUST be prefixed with VITE_
#  Server-side-only vars (no VITE_ prefix) are only available
#  in vite.config.ts / Node scripts, NOT in the browser bundle.
# ─────────────────────────────────────────────────────────────────


# ── App Identity ──────────────────────────────────────────────────
VITE_APP_NAME=AskIndia
VITE_APP_TAGLINE=India's Unified Marketplace
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
# development | staging | production
VITE_APP_URL=http://localhost:5173
VITE_APP_DOMAIN=askindia.shop
VITE_SUPPORT_EMAIL=support@askindia.shop
VITE_SUPPORT_PHONE=+91-9999999999


# ── Vite Dev Server ───────────────────────────────────────────────
VITE_PORT=5173
VITE_HOST=localhost
# Set to true to expose over LAN (npx vite --host)
VITE_NETWORK_EXPOSE=false


# ── Backend / API ─────────────────────────────────────────────────
# Replace with your actual REST or GraphQL API base URL
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_TIMEOUT=15000
# WebSocket for real-time order/notification updates
VITE_WS_URL=ws://localhost:8000/ws
# API key for server-to-server calls (Node scripts only — no VITE_ prefix)
API_SECRET_KEY=your_backend_secret_key_here


# ── Authentication ────────────────────────────────────────────────
# JWT / session
VITE_JWT_EXPIRY=7d
VITE_REFRESH_TOKEN_EXPIRY=30d

# Firebase Auth  (optional — swap Zustand auth for Firebase)
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=askindia-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=askindia-prod
VITE_FIREBASE_STORAGE_BUCKET=askindia-prod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# Server-side Firebase Admin (Node only)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"askindia-prod"}


# ── Payments — Razorpay (Primary Indian Gateway) ──────────────────
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXX
# Secret is server-side ONLY — never put in VITE_ prefix!
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
VITE_RAZORPAY_CURRENCY=INR
VITE_RAZORPAY_COMPANY_NAME=AskIndia Technologies Pvt. Ltd.
VITE_RAZORPAY_COMPANY_LOGO=https://askindia.shop/logo.png
VITE_RAZORPAY_THEME_COLOR=#F97316

# Cashfree (backup gateway)
VITE_CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_here
VITE_CASHFREE_ENV=TEST
# TEST | PROD


# ── OTP / SMS — MSG91 ─────────────────────────────────────────────
VITE_MSG91_SENDER_ID=ASKNDI
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_TEMPLATE_ID_OTP=your_otp_template_id_here
MSG91_TEMPLATE_ID_ORDER=your_order_sms_template_id_here
MSG91_TEMPLATE_ID_DELIVERY=your_delivery_sms_template_id_here


# ── Email — SendGrid ──────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_EMAIL_FROM=noreply@askindia.shop
VITE_EMAIL_FROM_NAME=AskIndia
SENDGRID_TEMPLATE_WELCOME=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_ORDER_CONFIRM=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_INVOICE=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_PASSWORD_RESET=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── WhatsApp Business API ─────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id_here


# ── File / Image Storage — Cloudinary ────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=askindia
VITE_CLOUDINARY_UPLOAD_PRESET=askindia_unsigned
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
VITE_CLOUDINARY_BASE_URL=https://res.cloudinary.com/askindia
# Max upload size in MB
VITE_MAX_IMAGE_SIZE_MB=5
VITE_MAX_IMAGES_PER_PRODUCT=8

# AWS S3 (alternative to Cloudinary)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
AWS_S3_BUCKET=askindia-assets
VITE_S3_BASE_URL=https://askindia-assets.s3.ap-south-1.amazonaws.com


# ── Location / Maps — Google ──────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Used for city autocomplete + store pin on map
VITE_DEFAULT_COUNTRY=IN
VITE_DEFAULT_CURRENCY=INR
VITE_DEFAULT_CURRENCY_SYMBOL=₹
VITE_DEFAULT_LOCALE=en-IN
VITE_DEFAULT_TIMEZONE=Asia/Kolkata


# ── Logistics / Shipping ──────────────────────────────────────────
# Shiprocket
SHIPROCKET_EMAIL=your_shiprocket_email@company.com
SHIPROCKET_PASSWORD=your_shiprocket_password_here
VITE_FREE_SHIPPING_ABOVE=999
# Delivery partner display names
VITE_LOGISTICS_PARTNER=Shiprocket


# ── Analytics ─────────────────────────────────────────────────────
# Google Analytics 4
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Meta Pixel
VITE_META_PIXEL_ID=000000000000000
# Hotjar (heatmaps)
VITE_HOTJAR_SITE_ID=0000000
VITE_HOTJAR_VERSION=6
# Clarity (Microsoft)
VITE_CLARITY_PROJECT_ID=xxxxxxxxxxxx
# Mixpanel
VITE_MIXPANEL_TOKEN=your_mixpanel_token_here


# ── Error Monitoring — Sentry ─────────────────────────────────────
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o0000000.ingest.sentry.io/0000000
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1


# ── Push Notifications — Firebase Cloud Messaging ─────────────────
VITE_FCM_VAPID_KEY=BNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FCM_SERVER_KEY=AAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── GST / Tax (India) ─────────────────────────────────────────────
VITE_DEFAULT_GST_RATE=18
# in %
VITE_GSTIN_COMPANY=29AABCA1234A1Z5
# AskIndia platform GSTIN
VITE_COMPANY_PAN=AABCA1234A
VITE_COMPANY_CIN=U74999KA2024PTC000000
VITE_COMPANY_ADDRESS=123 Tech Park, Whitefield, Bengaluru - 560066, Karnataka, India
VITE_COMPANY_STATE=Karnataka
VITE_COMPANY_STATE_CODE=29


# ── Platform Commission Rates ─────────────────────────────────────
VITE_DEFAULT_COMMISSION_PRODUCT=10
# % of order value
VITE_DEFAULT_COMMISSION_SERVICE=12
VITE_DEFAULT_COMMISSION_AGENT=8
VITE_MIN_WITHDRAWAL_AMOUNT=500
# in INR
VITE_WITHDRAWAL_PROCESSING_DAYS=3


# ── Social / OAuth ────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
VITE_FACEBOOK_APP_ID=0000000000000000
# Social media links shown in footer
VITE_SOCIAL_FACEBOOK=https://facebook.com/askindia
VITE_SOCIAL_INSTAGRAM=https://instagram.com/askindia
VITE_SOCIAL_TWITTER=https://twitter.com/askindia
VITE_SOCIAL_YOUTUBE=https://youtube.com/@askindia
VITE_SOCIAL_LINKEDIN=https://linkedin.com/company/askindia


# ── Feature Flags ─────────────────────────────────────────────────
# Set to true to enable, false to disable
VITE_FEATURE_REAL_AUTH=false
# true = Firebase/backend auth | false = Zustand mock auth
VITE_FEATURE_REAL_PAYMENTS=false
# true = Razorpay live | false = demo mode
VITE_FEATURE_REAL_UPLOADS=false
# true = Cloudinary | false = emoji/color placeholders
VITE_FEATURE_PUSH_NOTIFICATIONS=false
VITE_FEATURE_LIVE_CHAT=false
VITE_FEATURE_AGENT_PORTAL=true
VITE_FEATURE_SERVICE_BOOKING=true
VITE_FEATURE_GST_INVOICES=true
VITE_FEATURE_ANALYTICS=false
VITE_FEATURE_MAPS=false
VITE_FEATURE_COD=true
# Cash on Delivery


# ── Zustand Store ─────────────────────────────────────────────────
VITE_STORE_VERSION=3
VITE_STORE_KEY=askindia-store


# ── SEO / Meta ────────────────────────────────────────────────────
VITE_META_TITLE=AskIndia — India's Unified Marketplace
VITE_META_DESCRIPTION=Products from verified stores, services from trusted providers — all in your city.
VITE_META_OG_IMAGE=https://askindia.shop/og-image.jpg
VITE_META_THEME_COLOR=#0D1F6E
VITE_META_KEYWORDS=online shopping india, local stores, home services, ecommerce


# ── Legal / Compliance ────────────────────────────────────────────
VITE_PRIVACY_POLICY_URL=https://askindia.shop/privacy
VITE_TERMS_URL=https://askindia.shop/terms
VITE_REFUND_POLICY_URL=https://askindia.shop/refund
VITE_GRIEVANCE_EMAIL=grievance@askindia.shop
VITE_GRIEVANCE_OFFICER=Compliance Officer, AskIndia Technologies Pvt. Ltd.
